COMPILER = gcc
LINKER_SETTINGS = -Wall -Wextra -g
COMPILER_SETTINGS =  $(LINKER_SETTINGS) -c
EXECUTABLE_FILE = T86.out
OBJECT_FILES = main.o

all: $(EXECUTABLE_FILE)

$(EXECUTABLE_FILE): $(OBJECT_FILES)
	$(COMPILER) $(LINKER_SETTINGS) $(OBJECT_FILES) -o $(EXECUTABLE_FILE)
	
main.o: main.c
	$(COMPILER) $(COMPILER_SETTINGS) main.c
	
delete: 
	rm -f $(OBJECT_FILES) $(EXECUTABLE_FILE)	

